---
layout: base
tab: to-be-defined
---
#preservation-banner{:style => 'background: white; color: black; text-align: center; padding: 8px 0; font-size: 14px; font-family: Courier, monospace;'}
  This site is provided as part of the
  %a{:href => 'https://ceylon-lang.dev', :style => 'text-decoration: underline; color: black;'} Ceylon Preservation Project
.header-bar
  //cannot use a partial as it loses the page.tab context :(
  #header
    %a#header-logo{:href=>'/'}
      %h1
        Ceylon
    #header-tagline
      %p
        Say more, more clearly
    #menu
      %ul#menu-core
        - idname = page.tab == "home" ? "selected" : "notselected"
        %li{ :id=>"#{idname}" }
          %a{ :href=>'/' } HOME
        - idname = page.tab == "documentation" ? "selected" : "notselected"
        %li{ :id=>"#{idname}" }
          %a{ :href=>'/documentation/current' } LEARN
        - idname = page.tab == "download" ? "selected" : "notselected"
        %li{ :id=>"#{idname}" }
          %a{ :href=>'/download' } DOWNLOAD
        - idname = page.tab == "community" ? "selected" : "notselected"
        %li{ :id=>"#{idname}" }
          %a{ :href=>'/community' } COMMUNITY
        - idname = page.tab == "code" ? "selected" : "notselected"
        %li{ :id=>"#{idname}" }
          %a{ :href=>'/code' } CODE
        - idname = page.tab == "blog" ? "selected" : "notselected"
        %li{ :id=>"#{idname}" }
          %a{ :href=>'/blog' } BLOG
#primary-content
  ~ content
.footer-bar
  = partial( 'footer.html.haml' )
